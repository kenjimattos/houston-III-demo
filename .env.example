# Supabase local (gerado automaticamente pelo setup:demo)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<generated-by-supabase-status>
SUPABASE_SERVICE_ROLE_KEY=<generated-by-supabase-status>

# URL base da aplicação local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: habilita autocomplete/mapas do Google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
